{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "Daylight Dynamics",
  "description": "Adjust Minecraft daylight using a realtime timezone mode or a custom day-length mode with persisted settings.",
  "authors": [
    "opaleq"
  ],
  "license": "All Rights Reserved",
  "icon": "META-INF/mod_icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.cookiecraftmods.timeadjustmentmod.DaylightDynamicsMod"
    ],
    "client": [
      "com.cookiecraftmods.timeadjustmentmod.client.DaylightDynamicsClient"
    ]
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=21",
    "fabric-api": ">=${fabric_api_version}"
  }
}
